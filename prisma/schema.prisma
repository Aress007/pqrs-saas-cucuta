// ============================================
// MODELO DE NEGOCIO SaaS PARA GESTIÓN INTELIGENTE DE PQRS
// Microempresas del Área Metropolitana de Cúcuta
// Proyecto SENA - Etapa Productiva I+D+i
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELO: EMPRESA (Cliente SaaS)
// ============================================
model Empresa {
  id                String    @id @default(cuid())
  nombre            String
  nit               String    @unique
  direccion         String?
  telefono          String?
  email             String    @unique
  ciudad            String    @default("Cúcuta")
  planType          PlanType  @default(TRIAL)
  trialStartDate    DateTime? @default(now())
  trialEndDate      DateTime?
  isActive          Boolean   @default(true)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  usuarios    Usuario[]
  pqrs        Pqrs[]
  categorias  Categoria[]
  respuestas  RespuestaAutomatica[]

  @@map("empresas")
}

// ============================================
// MODELO: USUARIO (Empleados de la empresa)
// ============================================
model Usuario {
  id           String     @id @default(cuid())
  email        String     @unique
  password     String
  nombre       String
  apellido     String?
  rol          RolUsuario @default(EMPLEADO)
  activo       Boolean    @default(true)
  empresaId    String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  ultimoAcceso DateTime?

  empresa       Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  pqrsAsignadas Pqrs[]        @relation("PqrsAsignado")
  seguimientos  Seguimiento[]

  @@index([empresaId])
  @@map("usuarios")
}

// ============================================
// MODELO: PQRS (Peticiones, Quejas, Reclamos, Sugerencias)
// ============================================
model Pqrs {
  id                 String        @id @default(cuid())
  radicado           String        @unique
  tipo               TipoPqrs
  titulo             String
  descripcion        String
  prioridad          Prioridad     @default(MEDIA)
  estado             EstadoPqrs    @default(PENDIENTE)
  categoriaIA        String?
  confianzaIA        Float?
  sentimientoIA      Sentimiento?
  nombreCiudadano    String
  emailCiudadano     String?
  telefonoCiudadano  String?
  direccionCiudadano String?
  fechaRecepcion     DateTime      @default(now())
  fechaLimite        DateTime?
  fechaCierre        DateTime?
  asignadoA          String?
  empresaId          String
  categoriaId        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  categoria  Categoria?  @relation(fields: [categoriaId], references: [id])
  asignado   Usuario?    @relation("PqrsAsignado", fields: [asignadoA], references: [id])
  seguimientos Seguimiento[]
  archivos     Archivo[]

  @@index([empresaId])
  @@index([estado])
  @@index([fechaRecepcion])
  @@map("pqrs")
}

// ============================================
// MODELO: CATEGORÍA (Para clasificación)
// ============================================
model Categoria {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  color       String   @default("#3B82F6")
  activo      Boolean  @default(true)
  empresaId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  pqrs    Pqrs[]

  @@unique([nombre, empresaId])
  @@index([empresaId])
  @@map("categorias")
}

// ============================================
// MODELO: SEGUIMIENTO (Historial de PQRS)
// ============================================
model Seguimiento {
  id          String          @id @default(cuid())
  descripcion String
  tipo        TipoSeguimiento
  pqrsId      String
  usuarioId   String
  createdAt   DateTime        @default(now())

  pqrs    Pqrs    @relation(fields: [pqrsId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([pqrsId])
  @@index([usuarioId])
  @@map("seguimientos")
}

// ============================================
// MODELO: ARCHIVO ADJUNTO
// ============================================
model Archivo {
  id        String   @id @default(cuid())
  nombre    String
  tipo      String
  tamano    Int
  url       String
  pqrsId    String
  createdAt DateTime @default(now())

  pqrs Pqrs @relation(fields: [pqrsId], references: [id], onDelete: Cascade)

  @@index([pqrsId])
  @@map("archivos")
}

// ============================================
// MODELO: RESPUESTA AUTOMÁTICA (Plantillas)
// ============================================
model RespuestaAutomatica {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  categoria String
  empresaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@map("respuestas_automaticas")
}

// ============================================
// MODELO: ESTADÍSTICAS (Para Dashboard)
// ============================================
model Estadistica {
  id             String   @id @default(cuid())
  fecha          DateTime @default(now())
  totalPqrs      Int      @default(0)
  pendientes     Int      @default(0)
  enProceso      Int      @default(0)
  resueltos      Int      @default(0)
  tiempoPromedio Float?
  empresaId      String

  @@index([empresaId])
  @@map("estadisticas")
}

// ============================================
// ENUMS
// ============================================

enum PlanType {
  TRIAL
  MICRO
  ENTERPRISE
}

enum RolUsuario {
  ADMIN
  EMPLEADO
  SUPERADMIN
}

enum TipoPqrs {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
  DENUNCIA
  FELICITACION
}

enum EstadoPqrs {
  PENDIENTE
  ASIGNADO
  EN_PROCESO
  ESPERA_INFO
  RESUELTO
  CERRADO
  RECHAZADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  URGENCIA
}

enum Sentimiento {
  POSITIVO
  NEUTRO
  NEGATIVO
  MUY_NEGATIVO
}

enum TipoSeguimiento {
  COMENTARIO
  CAMBIO_ESTADO
  ASIGNACION
  RESPUESTA
  CIERRE
  REAPERTURA
}
